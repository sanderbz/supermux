#!/usr/bin/env bash
# cargo-guard wrapper. Installed to ~/.local/bin/cargo on hosts where the
# operator opted in (SUPERMUX_INSTALL_CARGO_GUARD=1 in scripts/deploy.sh).
# Sits ahead of rustup's cargo in PATH and refuses `--release` unless the
# caller sets SUPERMUX_RELEASE_OK=1 — the legit deploy paths (build.sh,
# deploy-self.sh) do; agent ad-hoc compile-checks don't. Reason: release
# builds peak ~2 GB/rustc and can OOM-thrash small hosts.
set -euo pipefail

REAL_CARGO="${HOME}/.cargo/bin/cargo"

if [ ! -x "$REAL_CARGO" ]; then
  PATH="$(printf '%s\n' "$PATH" | awk -v RS=: -v ORS=: -v me="$(dirname "$0")" '$0 != me' | sed 's/:$//')" \
    exec cargo "$@"
fi

if [ "${SUPERMUX_RELEASE_OK:-0}" = "1" ]; then
  exec "$REAL_CARGO" "$@"
fi

for arg in "$@"; do
  case "$arg" in
    --release)
      cat >&2 <<EOF
[cargo-guard] REFUSED on $(hostname): \`cargo $* \`

Release builds can OOM-thrash small hosts. Use \`cargo check\` or
\`cargo build\` (debug). For real deploys: \`bash scripts/deploy-self.sh\`
(on-server) or \`bash scripts/deploy.sh\` (from your Mac) — both set
SUPERMUX_RELEASE_OK=1 internally and let this wrapper through.
EOF
      exit 99
      ;;
  esac
done

exec "$REAL_CARGO" "$@"

# supermux deploy configuration — copy to `.env` and fill in your values.
# `scripts/deploy.sh` sources `.env` automatically if it exists. `.env` is
# gitignored; this file (`.env.example`) is committed as documentation.
#
# QUICKSTART: copy this file to `.env`, set SUPERMUX_DEPLOY_HOST, run
# `scripts/deploy.sh`. Everything else has sensible defaults — the service
# user is auto-created, ReadWritePaths defaults to a sane multi-project set,
# and Tailscale exposure is auto-detected from whether `tailscaled` is up.

# SSH target to deploy to (hostname or user@host). REQUIRED — no default.
SUPERMUX_DEPLOY_HOST=my-host

# Unix account on the host that owns the data dir and runs the service.
# If left as the default ("supermux") and the user doesn't yet exist on the
# host, `deploy.sh` auto-creates it for you (`sudo useradd -m -s /bin/bash
# supermux`). If you pick a non-default user, you must create it yourself
# first — `deploy.sh` will refuse rather than silently create an unexpected
# account. SUPERMUX_SERVICE_USER=root is refused unless SUPERMUX_ALLOW_ROOT=1
# is also set (see below).
SUPERMUX_SERVICE_USER=supermux

# Opt out of the User=root refusal. When 1, deploy.sh renders the unit with
# relaxed hardening (ProtectHome=false, ReadWritePaths=/root) so a root-owned
# data dir under /root/.supermux is reachable. The other hardening directives
# still apply, but the user-isolation trade-off is on you. Default: 0.
# SUPERMUX_ALLOW_ROOT=0

# Data directory on the host (holds the SQLite DB, auth token, config.toml,
# uploads). DELIBERATELY SEPARATE from SUPERMUX_USER_HOME: keeping the data
# dir scoped to its own tree means a `rm -rf $SUPERMUX_DATA_DIR` does not
# nuke the user's shell history or agent caches, and dotfiles from spawned
# shells/agents do not pollute the data dir. Default derives from
# SUPERMUX_SERVICE_USER: <user-home>/.supermux for non-root, /root/.supermux
# for root.
# SUPERMUX_DATA_DIR=/home/supermux/.supermux

# Extra writable roots for the systemd ReadWritePaths= directive — colon
# separated. When unset, `deploy.sh` derives a sane default: the data dir, the
# service user's home directory, and /opt/projects (only if that dir exists on
# the host). That covers single-user, single-project, and the common
# multi-project layout out of the box. Override only if you need something
# else, e.g.:
# SUPERMUX_READ_WRITE_PATHS=/home/supermux:/opt/projects:/srv/scratch

# Loopback port the server binds to on the host (plain HTTP).
# SUPERMUX_INTERNAL_PORT=8824

# Public HTTPS port — used only when Tailscale is enabled (see below).
# Default 443 gives you the clean URL `https://<host>.<tailnet>.ts.net/` (no
# port suffix). Tailscale terminates TLS natively on 443 inside the tailnet —
# tip: rename the host with `sudo tailscale set --hostname=supermux` so the
# URL reads `https://supermux.<your-tailnet>.ts.net/`. Set to another port
# (e.g. 8443) only if 443 is already taken by another tailscale-serve binding.
# SUPERMUX_PUBLIC_PORT=443

# Expose the service via `tailscale serve`. When unset, `deploy.sh`
# auto-detects: if the host has `tailscale` installed AND `tailscaled` is
# running, it defaults to 1 (expose). Otherwise it defaults to 0 (skip — you
# front the loopback port with your own reverse proxy: nginx, Caddy, …).
# Override with 0 or 1 to force either behaviour.
# SUPERMUX_USE_TAILSCALE=1

# Build/source directory on the host (a pinned git archive is unpacked here).
# SUPERMUX_REMOTE_DIR=/opt/supermux

# Git ref to deploy. The working tree must be clean; defaults to HEAD.
# SUPERMUX_DEPLOY_REF=HEAD

# ─── Advanced / opt-in ────────────────────────────────────────────────────

# Service user's login HOME on the host. The systemd unit's WorkingDirectory
# and $HOME both point here so spawned shells/agents (claude, codex, tmux
# children) resolve their dotfiles (.bash_history, .claude/, .claude.json,
# .cache/, .local/, …) in the conventional place — NOT inside the supermux
# data dir. By default deploy.sh derives this from SUPERMUX_SERVICE_USER:
# `/root` for root, `getent passwd <user>` if the account exists locally,
# `/home/<user>` otherwise. Set this explicitly only for non-standard layouts
# (e.g. accounts homed under /srv or /var/lib).
# SUPERMUX_USER_HOME=/home/supermux

# Opt in to automatic toolchain installation on the host. When the host is
# missing `bun` or `cargo` and this is set to 1, `deploy.sh` installs them
# under the service user's home using the official installers (bun pinned to
# your local bun version; rustup with --default-toolchain stable). Without
# this opt-in, a missing toolchain is a hard error with manual-install
# instructions. Default: 0.
# SUPERMUX_INSTALL_TOOLCHAINS=0

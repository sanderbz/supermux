# supermux deploy configuration — copy to `.env` and fill in your values.
# `scripts/deploy.sh` sources `.env` automatically if it exists. `.env` is
# gitignored; this file (`.env.example`) is committed as documentation.

# SSH target to deploy to (hostname or user@host). REQUIRED — no default.
SUPERMUX_DEPLOY_HOST=my-host

# Unix account on the host that owns the data dir and runs the service.
# SUPERMUX_SERVICE_USER=root is refused by default — the systemd hardening
# directives (ProtectHome=true) would mask /root and the unit wouldn't start.
# To deploy as root anyway, also set SUPERMUX_ALLOW_ROOT=1 (deploy.sh then
# renders the unit with ProtectHome=false + ReadWritePaths=/root).
SUPERMUX_SERVICE_USER=supermux

# Opt out of the User=root refusal. When 1, deploy.sh renders the unit with
# relaxed hardening (ProtectHome=false, ReadWritePaths=/root) so a root-owned
# data dir under /root/.supermux is reachable. The other hardening directives
# still apply, but the user-isolation trade-off is on you. Default: 0.
# SUPERMUX_ALLOW_ROOT=0

# Service user's login HOME on the host. The systemd unit's WorkingDirectory
# and $HOME both point here so spawned shells/agents (claude, codex, tmux
# children) resolve their dotfiles (.bash_history, .claude/, .claude.json,
# .cache/, .local/, …) in the conventional place — NOT inside the supermux
# data dir. By default deploy.sh derives this from SUPERMUX_SERVICE_USER:
# `/root` for root, `getent passwd <user>` if the account exists locally,
# `/home/<user>` otherwise. Set this explicitly only for non-standard layouts
# (e.g. accounts homed under /srv or /var/lib).
# SUPERMUX_USER_HOME=/home/supermux

# Data directory on the host (holds the SQLite DB, auth token, config.toml,
# uploads). DELIBERATELY SEPARATE from SUPERMUX_USER_HOME: keeping the data
# dir scoped to its own tree means a `rm -rf $SUPERMUX_DATA_DIR` does not
# nuke the user's shell history or agent caches, and dotfiles from spawned
# shells/agents do not pollute the data dir. Default derives from
# SUPERMUX_SERVICE_USER: <user-home>/.supermux for non-root, /root/.supermux
# for root.
SUPERMUX_DATA_DIR=/home/supermux/.supermux

# Extra writable roots for the systemd ReadWritePaths= directive — colon
# separated. Defaults to the data dir. Broaden it if tmux/git/claude sessions
# write into project dirs outside the data dir (multi-project workflows):
# SUPERMUX_READ_WRITE_PATHS=/home/supermux:/opt/projects

# Loopback port the server binds to on the host (plain HTTP).
SUPERMUX_INTERNAL_PORT=8824

# Public HTTPS port — used only when SUPERMUX_USE_TAILSCALE=1 (tailscale serve).
SUPERMUX_PUBLIC_PORT=8823

# Set to 1 to expose the service via `tailscale serve`. When unset/0, deploy.sh
# skips Tailscale and you front the loopback port with your own reverse proxy.
SUPERMUX_USE_TAILSCALE=0

# Build/source directory on the host (a pinned git archive is unpacked here).
SUPERMUX_REMOTE_DIR=/opt/supermux

# Git ref to deploy. The working tree must be clean; defaults to HEAD.
SUPERMUX_DEPLOY_REF=HEAD
